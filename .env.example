# Portkey AI Gateway API key — required.
# Paste your Portkey key into .env.local for local development.
# Get one at https://app.portkey.ai/settings
PORTKEY_API_KEY="pk-..."

# Port for the Express host (default: 10337)
# PORT=10337

# Set to "true" to disable Vite HMR (useful inside AI Studio / ephemeral sandboxes).
# DISABLE_HMR=false
