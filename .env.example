# Optional model gateway API key for model-assisted blueprints.
# Omit this and set REDESIGN_MODEL=local for fully deterministic local builds.
# Paste your Portkey key into .env.local for local development when using the gateway.
PORTKEY_API_KEY="pk-..."

# Optional: use "local" to force deterministic local-only blueprints.
# Use your configured gateway model name for model-assisted blueprints.
# REDESIGN_MODEL=local
# PORTKEY_VIRTUAL_KEY="portkeyopenai"

# Optional direct provider key for model-assisted blueprints.
# OPENAI_API_KEY="sk-..."

# Port for the Express host (default: 10337)
# PORT=10337

# Set to "true" to disable Vite HMR (useful inside AI Studio / ephemeral sandboxes).
# DISABLE_HMR=false
