# API key for server-side redesign generation. Required.
# Paste a valid key into .env.local for local development.
ANTHROPIC_API_KEY="sk-ant-..."

# Port for the Express host (default: 10337)
# PORT=10337

# Set to "true" to disable Vite HMR (useful inside AI Studio / ephemeral sandboxes).
# DISABLE_HMR=false
