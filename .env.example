# Anthropic API key — required. Used ONLY server-side (never shipped to the browser).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Port for the Express host (default: 3000)
# PORT=3000

# Set to "true" to disable Vite HMR (useful inside AI Studio / ephemeral sandboxes).
# DISABLE_HMR=false
